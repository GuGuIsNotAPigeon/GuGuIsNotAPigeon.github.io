            <pubDate>Sat, 25 Apr 2026 13:31:55 +0800</pubDate>
            <guid>https://guguisnotapigeon.github.io/ja/p/%E5%88%9D%E3%82%81%E3%81%A6%E3%81%AE%E3%83%96%E3%83%AD%E3%82%B0/</guid>
